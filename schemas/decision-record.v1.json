{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fulcrum-governance.github.io/boundary/schemas/decision-record.v1.json",
  "title": "Boundary Decision Record v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "schema_version",
    "record_id",
    "timestamp",
    "action",
    "decision_hash",
    "trust_score"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "event_type": {
      "type": "string"
    },
    "record_id": {
      "type": "string",
      "pattern": "^rec_[a-f0-9]+$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time"
    },
    "boundary_version": {
      "type": "string"
    },
    "boundary_build_digest": {
      "type": "string"
    },
    "adapter": {
      "type": "string"
    },
    "agent_id": {
      "type": "string"
    },
    "tenant_id": {
      "type": "string"
    },
    "trace_id": {
      "type": "string"
    },
    "tool": {
      "type": "string"
    },
    "action": {
      "enum": ["allow", "deny", "warn", "escalate", "require_approval"]
    },
    "reason": {
      "type": "string"
    },
    "decision_mode": {
      "enum": ["deterministic", "classified", "proved", "human_approved", ""]
    },
    "matched_rule": {
      "type": "string"
    },
    "policy_file": {
      "type": "string"
    },
    "policy_bundle_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "request_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "raw_shape_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "decision_hash": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "trust_score": {
      "type": "number"
    },
    "trust_state": {
      "type": "string"
    },
    "signature": {
      "type": "string"
    },
    "signature_key_id": {
      "type": "string"
    }
  }
}
